# Copy this file to .env and fill in your real values.
# NEVER commit your real .env to GitHub.

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Your Telegram user ID(s) — comma-separated if multiple
# Get yours by messaging @userinfobot on Telegram
ALLOWED_CHAT_IDS=your-telegram-user-id-here

# Directory where your input text dataset lives
SOURCE_DIR=/data/textset

# Directory where Falcon writes result files
OUT_DIR=/data/archives

# Python binary to use (default: python3)
PYTHON_BIN=python3
